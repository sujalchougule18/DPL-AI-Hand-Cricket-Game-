<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Hand Cricket – DOMINTOR's Premier League</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      user-select: none;
    }

    body {
      background: radial-gradient(circle at 10% 20%, #03190e, #010b06);
      color: #f5f0e0;
      font-family: 'Barlow', sans-serif;
      min-height: 100vh;
      padding: 1.5rem 1rem;
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
    }

    /* Header */
    .premier-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid #2d6a4f;
      padding-bottom: 1.2rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .trophy-icon {
      width: 44px;
      height: 44px;
      background: linear-gradient(145deg, #c9a84c, #b88a2c);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 16px rgba(201,168,76,0.6);
    }

    .trophy-icon svg {
      width: 24px;
      height: 24px;
      color: #0a1f14;
    }

    h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.8rem;
      line-height: 1;
      letter-spacing: 2px;
    }

    .season-badge {
      font-size: 0.7rem;
      text-transform: uppercase;
      background: rgba(45,106,79,0.3);
      padding: 6px 14px;
      border-radius: 40px;
      border: 1px solid #2d6a4f;
      letter-spacing: 1px;
    }

    /* Main grid */
    .game-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }

    @media (min-width: 1024px) {
      .game-grid {
        grid-template-columns: 1fr 340px;
      }
    }

    /* Cards */
    .card-panel {
      background: rgba(10,31,20,0.85);
      backdrop-filter: blur(2px);
      border: 1px solid #2d6a4f;
      border-radius: 28px;
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.5);
      overflow: hidden;
    }

    .scoreboard-duel {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid #2d6a4f;
    }

    .team-panel {
      padding: 1.6rem 1.2rem;
      transition: all 0.2s;
      text-align: center;
    }

    .team-panel.active {
      background: linear-gradient(120deg, rgba(13,122,95,0.3), transparent);
      box-shadow: inset 0 0 20px rgba(201,168,76,0.1);
    }

    .team-label {
      font-size: 12px;
      letter-spacing: 3px;
      color: #8da395;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .live-dot {
      width: 8px;
      height: 8px;
      background: #c9a84c;
      border-radius: 50%;
      animation: pulseLive 1.4s infinite;
    }

    @keyframes pulseLive {
      0% { opacity: 1; transform: scale(1);}
      100% { opacity: 0.3; transform: scale(1.2);}
    }

    .score-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 4.2rem;
      line-height: 1;
      margin-top: 6px;
      letter-spacing: 2px;
    }

    .wicket-detail {
      font-size: 1.7rem;
      color: #a7c0b2;
      font-family: 'Bebas Neue', sans-serif;
    }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      background: #05140e;
      border-bottom: 1px solid #1f4d3a;
    }

    .stat-cell {
      padding: 1rem;
      text-align: center;
      border-right: 1px solid #1f4d3a;
    }

    .stat-cell:last-child {
      border-right: none;
    }

    .stat-title {
      font-size: 10px;
      letter-spacing: 2px;
      color: #8da395;
    }

    .stat-figure {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      margin-top: 4px;
    }

    .pitch-deck {
      padding: 1.5rem;
    }

    .match-message {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.7rem;
      background: #071c12;
      border-radius: 40px;
      padding: 10px 18px;
      text-align: center;
      margin-bottom: 1.8rem;
      border-left: 5px solid #c9a84c;
    }

    .ball-showcase {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .choice-card {
      flex: 1;
      background: #0e241a;
      border-radius: 20px;
      padding: 0.8rem;
      text-align: center;
      border: 1px solid #2d6a4f;
      transition: all 0.2s;
    }

    .choice-card.highlight {
      border-color: #c9a84c;
      background: #122e21;
      box-shadow: 0 0 12px rgba(201,168,76,0.3);
    }

    .choice-label {
      font-size: 9px;
      letter-spacing: 2px;
      color: #8da395;
      text-transform: uppercase;
    }

    .choice-value {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      line-height: 1.2;
    }

    .btn-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
      margin-top: 10px;
    }

    .cricket-btn {
      background: #0b1e15;
      border: 1px solid #2d6a4f;
      color: #f5f0e0;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      padding: 0.9rem 0;
      border-radius: 40px;
      cursor: pointer;
      transition: all 0.18s;
      font-weight: 500;
      letter-spacing: 1px;
    }

    .cricket-btn:hover:not(:disabled) {
      background: #c9a84c;
      color: #020e09;
      transform: translateY(-3px);
      border-color: #e6c87a;
      box-shadow: 0 8px 18px rgba(0,0,0,0.3);
    }

    .cricket-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .new-match-btn {
      width: 100%;
      background: linear-gradient(95deg, #c9a84c, #dbb85c);
      border: none;
      padding: 14px;
      margin-top: 25px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 2px;
      border-radius: 60px;
      color: #031208;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-weight: bold;
    }

    /* Sidebar */
    .info-card {
      background: rgba(10,31,20,0.85);
      border: 1px solid #2d6a4f;
      border-radius: 28px;
      padding: 1.3rem;
      margin-bottom: 1.5rem;
    }

    .info-header {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-bottom: 1rem;
      border-bottom: 1px dashed #2d6a4f;
      padding-bottom: 8px;
    }

    .info-header svg {
      width: 20px;
      color: #c9a84c;
    }

    .rules-list {
      list-style: none;
    }

    .rules-list li {
      display: flex;
      gap: 12px;
      font-size: 0.85rem;
      margin-bottom: 12px;
      color: #cbd8cf;
    }

    .commentary-box {
      max-height: 360px;
      overflow-y: auto;
      padding-right: 4px;
    }

    .comm-entry {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid #1f4d3a;
      font-size: 0.85rem;
    }

    .comm-ball {
      font-family: 'Bebas Neue', sans-serif;
      color: #c9a84c;
      width: 35px;
    }

    .comm-action {
      color: #b9cfc2;
    }

    .comm-result {
      font-weight: bold;
    }

    .wicket-badge {
      color: #ffb4a2;
      background: #631d1d60;
      padding: 2px 8px;
      border-radius: 20px;
    }

    .runs-badge {
      color: #c9a84c;
    }

    footer {
      text-align: center;
      margin-top: 2.5rem;
      font-size: 0.7rem;
      letter-spacing: 2px;
      color: #5a7f6b;
    }
  </style>
</head>
<body>
<div class="container">
  <div class="premier-header">
    <div class="brand">
      <div class="trophy-icon">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="9" />
          <path d="M12 7v5l3 3" />
        </svg>
      </div>
      <div>
        <h1>DOMINTOR's Premier League</h1>
      </div>
    </div>
    <div class="season-badge">⚡ FINAL SHOWDOWN ⚡</div>
  </div>

  <div class="game-grid">
    <div class="main-action">
      <div class="card-panel">
        <div class="scoreboard-duel">
          <div class="team-panel" id="playerTeamPanel">
            <div class="team-label">
              <span>🪓 YOU</span>
              <span id="playerLiveIcon"></span>
            </div>
            <div class="score-number" id="playerScoreDisplay">0</div>
            <div class="wicket-detail" id="playerWicketDisplay">/0</div>
          </div>
          <div class="team-panel" id="cpuTeamPanel">
            <div class="team-label">
              <span>🤖 CPU</span>
              <span id="cpuLiveIcon"></span>
            </div>
            <div class="score-number" id="cpuScoreDisplay">0</div>
            <div class="wicket-detail" id="cpuWicketDisplay">/0</div>
          </div>
        </div>

        <div class="stats-row">
          <div class="stat-cell"><div class="stat-title">OVERS</div><div class="stat-figure" id="oversFigure">0.0</div></div>
          <div class="stat-cell"><div class="stat-title">BALLS LEFT</div><div class="stat-figure" id="ballsLeftSpan">12</div></div>
          <div class="stat-cell"><div class="stat-title">RUN RATE</div><div class="stat-figure" id="runRateSpan">0.00</div></div>
          <div class="stat-cell"><div class="stat-title" id="targetTitle">TARGET</div><div class="stat-figure" id="targetFigure">—</div></div>
        </div>

        <div class="pitch-deck">
          <div class="match-message" id="dynamicMessage">🏏 You're batting first. Pick your number!</div>

          <div class="ball-showcase">
            <div class="choice-card" id="playerPickCard">
              <div class="choice-label" id="playerPickLabel">YOUR SHOT</div>
              <div class="choice-value" id="playerPickValue">—</div>
            </div>
            <div class="choice-card" id="cpuPickCard">
              <div class="choice-label" id="cpuPickLabel">CPU DELIVERY</div>
              <div class="choice-value" id="cpuPickValue">—</div>
            </div>
          </div>

          <div class="controls-label" style="font-size:11px; letter-spacing:2px; margin-bottom:8px;" id="actionHint">🎯 SELECT YOUR NUMBER</div>
          <div class="btn-grid" id="actionButtonsGrid">
            <button class="cricket-btn" data-num="1">1</button>
            <button class="cricket-btn" data-num="2">2</button>
            <button class="cricket-btn" data-num="3">3</button>
            <button class="cricket-btn" data-num="4">4🔥</button>
            <button class="cricket-btn" data-num="6">6💥</button>
          </div>

          <button class="new-match-btn" id="resetMatchBtn" style="display: none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            PLAY AGAIN • NEW MATCH
          </button>
        </div>
      </div>
    </div>

    <div class="sidebar">
      <div class="info-card">
        <div class="info-header">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 6v12m-6-6h12"/></svg>
          <h3 style="font-family:'Bebas Neue'; font-size: 1.5rem;">RULES</h3>
        </div>
        <ul class="rules-list">
          <li>🎲 <strong>1,2,3,4,6</strong> — pick any number</li>
          <li>⚡ If your number <strong>matches CPU</strong> → OUT!</li>
          <li>🏃 Different numbers → runs = your chosen number</li>
          <li>🔄 12 balls per innings. Defend / chase the target!</li>
          <li>🧠 <strong>AI CPU</strong> – Learns your patterns and predicts your next move!</li>
        </ul>
      </div>

      <div class="info-card">
        <div class="info-header">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l3-3m0 0l3 3m-3-3v12"/><path d="M21 12l-3 3m0 0l-3-3m3 3V3"/></svg>
          <h3 style="font-family:'Bebas Neue'; font-size: 1.5rem;">LIVE COMMENTARY</h3>
        </div>
        <div class="commentary-box" id="commentaryBox">
          <div style="color:#6f9683; text-align:center;">⚡ Toss won by you, batting first ⚡</div>
        </div>
      </div>
    </div>
  </div>
  <footer>✧ HAND CRICKET • ULTIMATE PREMIER CLASH • DEVELOPED BY SUJAL ✧</footer>
</div>

<script>
  (function() {
    // ------------------- GAME CONSTANTS -------------------
    const VALID_NUMBERS = [1, 2, 3, 4, 6];
    const MAX_BALLS = 12;

    // ------------------- STATE VARIABLES -------------------
    let gamePhase = "batting";     // 'batting', 'bowling', 'ended'
    let playerRuns = 0;
    let cpuRuns = 0;
    let ballsUsed = 0;
    let target = null;
    let matchFinished = false;
    
    // Wicket flags
    let playerWicketLost = false;
    let cpuWicketLost = false;

    // --- AI Memory: record player's choices in each phase ---
    let playerBattingHistory = [];   // shots when user is batting
    let playerBowlingHistory = [];   // deliveries when user is bowling

    // Commentary history
    let commentaryHistory = [];

    // ------------------- DOM ELEMENTS -------------------
    const playerScoreEl = document.getElementById("playerScoreDisplay");
    const cpuScoreEl = document.getElementById("cpuScoreDisplay");
    const playerWicketEl = document.getElementById("playerWicketDisplay");
    const cpuWicketEl = document.getElementById("cpuWicketDisplay");
    const playerPanel = document.getElementById("playerTeamPanel");
    const cpuPanel = document.getElementById("cpuTeamPanel");
    const playerLiveIcon = document.getElementById("playerLiveIcon");
    const cpuLiveIcon = document.getElementById("cpuLiveIcon");
    const oversEl = document.getElementById("oversFigure");
    const ballsLeftEl = document.getElementById("ballsLeftSpan");
    const runRateEl = document.getElementById("runRateSpan");
    const targetTitleEl = document.getElementById("targetTitle");
    const targetValueEl = document.getElementById("targetFigure");
    const messageBox = document.getElementById("dynamicMessage");
    const playerPickValueSpan = document.getElementById("playerPickValue");
    const cpuPickValueSpan = document.getElementById("cpuPickValue");
    const playerPickLabelSpan = document.getElementById("playerPickLabel");
    const cpuPickLabelSpan = document.getElementById("cpuPickLabel");
    const actionHintSpan = document.getElementById("actionHint");
    const resetBtn = document.getElementById("resetMatchBtn");
    const commentaryContainer = document.getElementById("commentaryBox");
    const actionButtons = document.querySelectorAll("[data-num]");

    // ---------- AI PREDICTION: MOST FREQUENT NUMBER (MODE) ----------
    function getAIPrediction(historyArray) {
      if (!historyArray.length) {
        // No data yet: random choice
        return VALID_NUMBERS[Math.floor(Math.random() * VALID_NUMBERS.length)];
      }
      // Count frequencies of each number in history (last 8 moves for recency)
      const recent = historyArray.slice(-8);
      const freq = {};
      for (let num of recent) {
        freq[num] = (freq[num] || 0) + 1;
      }
      let bestNum = recent[0];
      let bestFreq = 0;
      for (let [num, count] of Object.entries(freq)) {
        if (count > bestFreq) {
          bestFreq = count;
          bestNum = parseInt(num);
        }
      }
      return bestNum;
    }

    // ---------- HELPER FUNCTIONS ----------
    function updateUI() {
      playerScoreEl.innerText = playerRuns;
      cpuScoreEl.innerText = cpuRuns;

      let displayPlayerWickets = 0;
      let displayCpuWickets = 0;
      if (gamePhase === "batting") {
        displayPlayerWickets = playerWicketLost ? 1 : 0;
        displayCpuWickets = 0;
      } else if (gamePhase === "bowling") {
        displayPlayerWickets = 1;
        displayCpuWickets = cpuWicketLost ? 1 : 0;
      } else {
        displayPlayerWickets = playerWicketLost ? 1 : 0;
        displayCpuWickets = cpuWicketLost ? 1 : 0;
      }
      playerWicketEl.innerText = `/${displayPlayerWickets}`;
      cpuWicketEl.innerText = `/${displayCpuWickets}`;

      if (!matchFinished) {
        if (gamePhase === "batting") {
          playerPanel.classList.add("active");
          cpuPanel.classList.remove("active");
          playerLiveIcon.innerHTML = '<span class="live-dot"></span>';
          cpuLiveIcon.innerHTML = '<span style="font-size:10px;">waiting</span>';
        } else if (gamePhase === "bowling") {
          playerPanel.classList.remove("active");
          cpuPanel.classList.add("active");
          playerLiveIcon.innerHTML = '<span style="font-size:10px;">done</span>';
          cpuLiveIcon.innerHTML = '<span class="live-dot"></span>';
        }
      } else {
        playerPanel.classList.remove("active");
        cpuPanel.classList.remove("active");
        playerLiveIcon.innerHTML = '<span style="font-size:10px;">🏆</span>';
        cpuLiveIcon.innerHTML = '<span style="font-size:10px;">🏆</span>';
      }

      const overs = Math.floor(ballsUsed / 6);
      const ballInOver = ballsUsed % 6;
      oversEl.innerText = `${overs}.${ballInOver}`;
      const ballsRemaining = Math.max(0, MAX_BALLS - ballsUsed);
      ballsLeftEl.innerText = ballsRemaining;

      const currentScore = (gamePhase === "batting") ? playerRuns : (gamePhase === "bowling" ? cpuRuns : (playerWicketLost ? playerRuns : cpuRuns));
      const rr = (ballsUsed === 0) ? 0 : (currentScore / ballsUsed).toFixed(2);
      runRateEl.innerText = rr;

      if (target !== null && gamePhase === "bowling") {
        targetTitleEl.innerText = "NEED";
        const required = Math.max(0, target - cpuRuns);
        targetValueEl.innerText = required;
      } else if (target !== null) {
        targetTitleEl.innerText = "TARGET";
        targetValueEl.innerText = target;
      } else {
        targetTitleEl.innerText = "TARGET";
        targetValueEl.innerText = "—";
      }

      if (gamePhase === "batting") {
        playerPickLabelSpan.innerText = "YOUR SHOT";
        cpuPickLabelSpan.innerText = "CPU DELIVERY";
        actionHintSpan.innerText = "🎯 PICK YOUR SHOT (1,2,3,4,6)";
      } else if (gamePhase === "bowling") {
        playerPickLabelSpan.innerText = "YOUR DELIVERY";
        cpuPickLabelSpan.innerText = "CPU SHOT";
        actionHintSpan.innerText = "⚡ CHOOSE YOUR BALL NUMBER";
      } else {
        actionHintSpan.innerText = "MATCH FINISHED";
      }
    }

    function addCommentary(ballNumber, userNum, cpuNum, isWicket, runsScored) {
      let resultHtml = "";
      if (isWicket) {
        resultHtml = `<span class="wicket-badge">🔥 OUT! ${userNum} vs ${cpuNum}</span>`;
      } else {
        resultHtml = `<span class="runs-badge">➕ ${runsScored} RUNS</span>`;
      }
      commentaryHistory.unshift({
        ball: ballNumber,
        user: userNum,
        cpu: cpuNum,
        wicket: isWicket,
        runs: runsScored,
        resultHtml: resultHtml
      });
      if (commentaryHistory.length > 20) commentaryHistory.pop();
      renderCommentary();
    }

    function renderCommentary() {
      if (!commentaryHistory.length) {
        commentaryContainer.innerHTML = '<div style="color:#6f9683; text-align:center;">✨ Waiting for first ball ✨</div>';
        return;
      }
      commentaryContainer.innerHTML = commentaryHistory.map(entry => `
        <div class="comm-entry">
          <div class="comm-ball">${entry.ball}</div>
          <div class="comm-action">${entry.user} 🆚 ${entry.cpu}</div>
          <div class="comm-result">${entry.resultHtml}</div>
        </div>
      `).join('');
    }

    function endBattingInnings() {
      target = playerRuns + 1;
      gamePhase = "bowling";
      ballsUsed = 0;
      cpuRuns = 0;
      cpuWicketLost = false;
      // Do NOT reset playerBowlingHistory here – keep it for AI in bowling phase
      updateUI();
      messageBox.innerText = `🏏 INNINGS BREAK! CPU needs ${target} runs in 12 balls.`;
      playerPickValueSpan.innerText = "—";
      cpuPickValueSpan.innerText = "—";
    }

    function finishMatch(victoryForPlayer, customMessage) {
      if (matchFinished) return;
      matchFinished = true;
      gamePhase = "ended";
      updateUI();
      messageBox.innerText = customMessage;
      resetBtn.style.display = "flex";
      actionButtons.forEach(btn => btn.disabled = true);
    }

    // ---------- CORE GAME LOGIC (with AI CPU) ----------
    function playBall(selectedNumber) {
      if (matchFinished) return;
      if (!VALID_NUMBERS.includes(selectedNumber)) return;

      // --- AI decides CPU number based on current phase and player history ---
      let cpuNumber;
      if (gamePhase === "batting") {
        // CPU is bowling: it wants to match player's shot. Use playerBattingHistory.
        cpuNumber = getAIPrediction(playerBattingHistory);
      } else { // bowling phase
        // CPU is batting: it wants to match player's delivery. Use playerBowlingHistory.
        cpuNumber = getAIPrediction(playerBowlingHistory);
      }

      playerPickValueSpan.innerText = selectedNumber;
      cpuPickValueSpan.innerText = cpuNumber;

      const isWicket = (selectedNumber === cpuNumber);
      const currentBall = ballsUsed + 1;

      // ----- BATTING PHASE (User batting) -----
      if (gamePhase === "batting") {
        // Record player's shot for AI learning (before outcome)
        playerBattingHistory.push(selectedNumber);
        
        if (isWicket) {
          playerWicketLost = true;
          addCommentary(currentBall, selectedNumber, cpuNumber, true, 0);
          messageBox.innerText = `❌ OUT! Both picked ${selectedNumber}. Your innings ends.`;
          updateUI();
          endBattingInnings();
          return;
        } else {
          const runs = selectedNumber;
          playerRuns += runs;
          addCommentary(currentBall, selectedNumber, cpuNumber, false, runs);
          messageBox.innerText = `💥 ${runs} runs! Great shot.`;
          ballsUsed++;
          updateUI();

          if (ballsUsed >= MAX_BALLS) {
            messageBox.innerText = `🏁 End of innings: ${playerRuns} runs. CPU needs ${playerRuns+1}.`;
            endBattingInnings();
          }
          return;
        }
      }
      
      // ----- BOWLING PHASE (User bowling / CPU batting) -----
      if (gamePhase === "bowling") {
        // Record player's delivery for AI learning
        playerBowlingHistory.push(selectedNumber);
        
        if (isWicket) {
          cpuWicketLost = true;
          addCommentary(currentBall, selectedNumber, cpuNumber, true, 0);
          messageBox.innerText = `🎉 WICKET! CPU is out! You win the match.`;
          updateUI();
          finishMatch(true, `🏆 CHAMPION! Bowled out CPU. Victory by ${(target - 1) - cpuRuns} runs 🏆`);
          return;
        } else {
          const runs = cpuNumber;
          cpuRuns += runs;
          addCommentary(currentBall, selectedNumber, cpuNumber, false, runs);
          messageBox.innerText = `⚡ CPU scores ${runs} runs. Chase continues.`;
          ballsUsed++;
          updateUI();

          if (cpuRuns >= target) {
            finishMatch(false, `💔 CPU chased it down! CPU wins by ${target - playerRuns} runs (hand-style).`);
            return;
          }
          if (ballsUsed >= MAX_BALLS) {
            finishMatch(true, `🏆 DRAMATIC VICTORY! Defended target by ${(target - 1) - cpuRuns} runs. You win!`);
            return;
          }
        }
      }
    }

    // ------------------- RESET GAME -------------------
    function resetGame() {
      gamePhase = "batting";
      playerRuns = 0;
      cpuRuns = 0;
      ballsUsed = 0;
      target = null;
      matchFinished = false;
      playerWicketLost = false;
      cpuWicketLost = false;
      
      // Reset AI memory
      playerBattingHistory = [];
      playerBowlingHistory = [];
      
      commentaryHistory = [];

      playerPickValueSpan.innerText = "—";
      cpuPickValueSpan.innerText = "—";
      messageBox.innerText = "🏏 You're batting first. Pick your number!";
      resetBtn.style.display = "none";

      actionButtons.forEach(btn => btn.disabled = false);

      updateUI();
      renderCommentary();
      commentaryContainer.innerHTML = '<div style="color:#6f9683; text-align:center;">⚡ New match · Batting first · AI opponent ready ⚡</div>';
    }

    // ------------------- EVENT LISTENERS -------------------
    actionButtons.forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const num = parseInt(btn.getAttribute("data-num"), 10);
        if (!isNaN(num) && !matchFinished) {
          playBall(num);
        }
      });
    });

    resetBtn.addEventListener("click", () => {
      resetGame();
    });

    resetGame();
  })();
</script>
</body>
</html>
